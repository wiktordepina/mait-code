{
  "env": {
    "MAIT_CODE_LOG_LEVEL": "INFO"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mc-hook-session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mc-hook-observe --trigger precompact",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mc-hook-observe --trigger session-end",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  }
}
