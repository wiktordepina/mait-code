{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project __MAIT_CODE_PROJECT__ mc-hook-session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project __MAIT_CODE_PROJECT__ mc-hook-observe --trigger precompact",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project __MAIT_CODE_PROJECT__ mc-hook-observe --trigger session-end",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "mait-reminders": {
      "command": "uv",
      "args": ["run", "--project", "__MAIT_CODE_PROJECT__", "mc-mcp-reminders"]
    }
  }
}
